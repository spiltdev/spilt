# Gateway Environment Variables

# LLM Provider Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Chain config (Base Sepolia by default; set to 8453 for mainnet)
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org

# Gateway operator wallet (signs completion receipts, manages pool)
OPERATOR_PRIVATE_KEY=0x...

# Provider sink addresses (registered on CapacityRegistry via setup script)
OPENAI_SINK_ADDRESS=0x...
ANTHROPIC_SINK_ADDRESS=0x...
GROQ_SINK_ADDRESS=0x...

# Upstash Redis (optional; falls back to local JSON + in-memory if unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Auth
CRON_SECRET=change-me

# Optional: custom port
PORT=3100
