{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pura.xyz/schemas/capacity-attestation.json",
  "title": "CapacityAttestation",
  "description": "A signed capacity declaration from a sink (operator). Contains the task type, declared capacity, and EIP-712 signature.",
  "type": "object",
  "required": ["taskTypeId", "sink", "capacity", "timestamp", "nonce", "signature"],
  "properties": {
    "taskTypeId": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$",
      "description": "BPE task type identifier (bytes32 hex)"
    },
    "sink": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$",
      "description": "Ethereum address of the capacity provider"
    },
    "capacity": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "Normalized capacity value (uint256 as string)"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "Attestation timestamp (uint256 as string)"
    },
    "nonce": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "Monotonic nonce for replay prevention (uint256 as string)"
    },
    "signature": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]+$",
      "description": "EIP-712 signature (hex)"
    },
    "domain": {
      "type": "string",
      "description": "Optional domain identifier (e.g., NOSTR_RELAY, NOSTR_DVM, OPENCLAW_AGENT)"
    },
    "rawMetrics": {
      "type": "object",
      "properties": {
        "throughput": { "type": "integer", "minimum": 0 },
        "latencyMs": { "type": "integer", "minimum": 0 },
        "errorRateBps": { "type": "integer", "minimum": 0, "maximum": 10000 }
      },
      "description": "Pre-normalization domain-specific metrics"
    }
  },
  "additionalProperties": false
}
