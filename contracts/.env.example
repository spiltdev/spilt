# Backpressure Economics - Environment Variables
# Copy to .env and fill in your values

# Base Sepolia RPC (public endpoint, or use Alchemy/Infura for reliability)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deployer private key (NEVER use a mainnet key here)
DEPLOYER_PRIVATE_KEY=

# Optional: Basescan API key for contract verification
BASESCAN_API_KEY=

# ─── Post-deployment addresses (set after running Deploy.s.sol) ───
STAKE_TOKEN=
STAKE_MANAGER=
CAPACITY_REGISTRY=
BACKPRESSURE_POOL=
PAYMENT_TOKEN=
PAYMENT_SUPER_TOKEN=
PRICING_CURVE=
COMPLETION_TRACKER=
OFFCHAIN_AGGREGATOR=
